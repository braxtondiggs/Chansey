{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "@typescript-eslint/no-floating-promises": "warn",
        "@typescript-eslint/require-await": "warn"
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "parserOptions": {
        "project": null
      },
      "rules": {}
    }
  ]
}
